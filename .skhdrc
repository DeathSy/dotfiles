alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

alt - b : yabai -m space --focus prev
alt - n : yabai -m space --focus next
alt + ctrl - b : yabai -m window --space prev; yabai -m space --focus prev;
alt + ctrl - n : yabai -m window --space next; yabai -m space --focus next;
alt + ctrl - c : yabai -m space --create && \
                   index="$(yabai -m query --spaces --display | jq 'map(select(."is-native-fullscreen" == false))[-1].index')" && \
                   yabai -m window --space "${index}" && \
                   yabai -m space --focus "${index}"

ctrl + shift - h : yabai -m display --focus west
ctrl + shift - l : yabai -m display --focus east

shift + alt - r : yabai -m space --rotate 270
shift + alt - y : yabai -m space --mirror y-axis
shift + alt - x : yabai -m space --mirror x-axis

shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

shift + alt - e : yabai -m space --balance

shift + alt - h : yabai -m window --warp west
shift + alt - j : yabai -m window --warp south
shift + alt - k : yabai -m window --warp north
shift + alt - l : yabai -m window --warp east

ctrl + shift + alt - h : yabai -m window --display west; yabai -m display --focust west;
ctrl + shift + alt - l : yabai -m window --display east; yabai -m display --focust east;

alt - z : yabai -m window --toggle zoom-fullscreen
