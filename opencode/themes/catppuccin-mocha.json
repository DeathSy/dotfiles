{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "cat_rosewater": "#f5e0dc",
    "cat_flamingo": "#f2cdcd",
    "cat_pink": "#f5c2e7",
    "cat_mauve": "#cba6f7",
    "cat_red": "#f38ba8",
    "cat_maroon": "#eba0ac",
    "cat_peach": "#fab387",
    "cat_yellow": "#f9e2af",
    "cat_green": "#a6e3a1",
    "cat_teal": "#94e2d5",
    "cat_sky": "#89dceb",
    "cat_sapphire": "#74c7ec",
    "cat_blue": "#89b4fa",
    "cat_lavender": "#b4befe",
    "cat_text": "#cdd6f4",
    "cat_subtext1": "#bac2de",
    "cat_subtext0": "#a6adc8",
    "cat_overlay2": "#9399b2",
    "cat_overlay1": "#7f849c",
    "cat_overlay0": "#6c7086",
    "cat_surface2": "#585b70",
    "cat_surface1": "#45475a",
    "cat_surface0": "#313244",
    "cat_base": "#1e1e2e",
    "cat_mantle": "#181825",
    "cat_crust": "#11111b"
  },
  "theme": {
    "primary": {
      "dark": "cat_blue",
      "light": "cat_blue"
    },
    "secondary": {
      "dark": "cat_mauve",
      "light": "cat_mauve"
    },
    "accent": {
      "dark": "cat_sapphire",
      "light": "cat_sapphire"
    },
    "error": {
      "dark": "cat_red",
      "light": "cat_red"
    },
    "warning": {
      "dark": "cat_yellow",
      "light": "cat_yellow"
    },
    "success": {
      "dark": "cat_green",
      "light": "cat_green"
    },
    "info": {
      "dark": "cat_sky",
      "light": "cat_sky"
    },
    "text": "none",
    "textMuted": {
      "dark": "cat_subtext0",
      "light": "cat_subtext0"
    },
    "background": "none",
    "backgroundPanel": "none",
    "backgroundElement": "none",
    "border": {
      "dark": "cat_surface1",
      "light": "cat_surface1"
    },
    "borderActive": {
      "dark": "cat_surface2",
      "light": "cat_surface2"
    },
    "borderSubtle": {
      "dark": "cat_surface0",
      "light": "cat_surface0"
    },
    "diffAdded": {
      "dark": "cat_green",
      "light": "cat_green"
    },
    "diffRemoved": {
      "dark": "cat_red",
      "light": "cat_red"
    },
    "diffContext": {
      "dark": "cat_overlay0",
      "light": "cat_overlay0"
    },
    "diffHunkHeader": {
      "dark": "cat_overlay1",
      "light": "cat_overlay1"
    },
    "diffHighlightAdded": {
      "dark": "cat_green",
      "light": "cat_green"
    },
    "diffHighlightRemoved": {
      "dark": "cat_red",
      "light": "cat_red"
    },
    "diffAddedBg": {
      "dark": "cat_surface0",
      "light": "cat_surface0"
    },
    "diffRemovedBg": {
      "dark": "cat_surface0",
      "light": "cat_surface0"
    },
    "diffContextBg": {
      "dark": "cat_surface0",
      "light": "cat_surface0"
    },
    "diffLineNumber": {
      "dark": "cat_overlay0",
      "light": "cat_overlay0"
    },
    "diffAddedLineNumberBg": {
      "dark": "cat_surface0",
      "light": "cat_surface0"
    },
    "diffRemovedLineNumberBg": {
      "dark": "cat_surface0",
      "light": "cat_surface0"
    },
    "markdownText": {
      "dark": "cat_text",
      "light": "cat_text"
    },
    "markdownHeading": {
      "dark": "cat_blue",
      "light": "cat_blue"
    },
    "markdownLink": {
      "dark": "cat_sky",
      "light": "cat_sky"
    },
    "markdownLinkText": {
      "dark": "cat_sapphire",
      "light": "cat_sapphire"
    },
    "markdownCode": {
      "dark": "cat_green",
      "light": "cat_green"
    },
    "markdownBlockQuote": {
      "dark": "cat_overlay1",
      "light": "cat_overlay1"
    },
    "markdownEmph": {
      "dark": "cat_maroon",
      "light": "cat_maroon"
    },
    "markdownStrong": {
      "dark": "cat_peach",
      "light": "cat_peach"
    },
    "markdownHorizontalRule": {
      "dark": "cat_surface1",
      "light": "cat_surface1"
    },
    "markdownListItem": {
      "dark": "cat_lavender",
      "light": "cat_lavender"
    },
    "markdownListEnumeration": {
      "dark": "cat_mauve",
      "light": "cat_mauve"
    },
    "markdownImage": {
      "dark": "cat_pink",
      "light": "cat_pink"
    },
    "markdownImageText": {
      "dark": "cat_flamingo",
      "light": "cat_flamingo"
    },
    "markdownCodeBlock": {
      "dark": "cat_text",
      "light": "cat_text"
    },
    "syntaxComment": {
      "dark": "cat_overlay0",
      "light": "cat_overlay0"
    },
    "syntaxKeyword": {
      "dark": "cat_mauve",
      "light": "cat_mauve"
    },
    "syntaxFunction": {
      "dark": "cat_blue",
      "light": "cat_blue"
    },
    "syntaxVariable": {
      "dark": "cat_text",
      "light": "cat_text"
    },
    "syntaxString": {
      "dark": "cat_green",
      "light": "cat_green"
    },
    "syntaxNumber": {
      "dark": "cat_peach",
      "light": "cat_peach"
    },
    "syntaxType": {
      "dark": "cat_yellow",
      "light": "cat_yellow"
    },
    "syntaxOperator": {
      "dark": "cat_sky",
      "light": "cat_sky"
    },
    "syntaxPunctuation": {
      "dark": "cat_overlay2",
      "light": "cat_overlay2"
    }
