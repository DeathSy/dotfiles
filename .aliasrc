alias python=/usr/local/bin/python3
alias pip=/usr/local/bin/pip3
alias vim=nvim
alias act="act --container-architecture linux/amd64"
alias ll='exa -l --icons --no-user --group-directories-first  --time-style long-iso'
alias l='exa -la --icons --no-user --group-directories-first  --time-style long-iso'
alias docker-start="colima start -V \"$HOME/workspace/appman\":w"
alias docker-stop="colima stop"
alias docker-reset="docker system prune --volumes -fa"